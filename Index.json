const fs = require('fs')
const path = require('path')

/**
 * Auto-count commands and categories from plugins folder
 * Expects plugins to export: module.exports = { command: ['menu','help'], category: 'GENERAL' }
 */
function getCategoryCounts(dir) {
    let counts = {}
    let total = 0

    const files = fs.readdirSync(dir)
    for (let file of files) {
        const filePath = path.join(dir, file)
        const stat = fs.statSync(filePath)

        if (stat.isDirectory()) {
            let sub = getCategoryCounts(filePath)
            total += sub.total
            for (let cat in sub.counts) {
                counts[cat] = (counts[cat] || 0) + sub.counts[cat]
            }
        } else if (file.endsWith('.js') &&!file.startsWith('_')) {
            try {
                delete require.cache[require.resolve(filePath)] // clear cache for fresh read
                const plugin = require(filePath)

                let cat = (plugin.category || 'UNCATEGORIZED').toUpperCase()
                let cmds = 0

                if (Array.isArray(plugin.command)) {
                    cmds = plugin.command.length
                } else if (typeof plugin.command === 'string') {
                    cmds = 1
                } else if (plugin.name) {
                    cmds = 1
                }

                counts[cat] = (counts[cat] || 0) + cmds
                total += cmds
            } catch (e) {
                counts['UNCATEGORIZED'] = (counts['UNCATEGORIZED'] || 0) + 1
                total += 1
            }
        }
    }
    return { counts, total }
}

const { counts: categoryCounts, total: totalCommands } = getCategoryCounts(path.join(__dirname, 'plugins'))

/**
 * Helper function for runtime formatting
 */
function runtime(seconds) {
    seconds = Number(seconds)
    let d = Math.floor(seconds / (3600 * 24))
    let h = Math.floor(seconds % (3600 * 24) / 3600)
    let m = Math.floor(seconds % 3600 / 60)
    let s = Math.floor(seconds % 60)

    let dDisplay = d > 0? d + 'd ' : ''
    let hDisplay = h > 0? h + 'h ' : ''
    let mDisplay = m > 0? m + 'm ' : ''
    let sDisplay = s > 0? s + 's' : ''
    return dDisplay + hDisplay + mDisplay + sDisplay
}

